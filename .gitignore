# pyenv
#   For a library or package, you might want to ignore these files since the 
#   exact version is often managed by the tool (like uv or poetry)
# .python-version

# pipenv
#   According to pypa/pipenv#1181, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or experience
#   different results with different lock files, manually delete it may help.
# Pipfile.lock

# poetry
#   Similar to pipenv, see https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to pipenv, see https://pdm.fming.dev/#use-pdm-in-a-project
.pdm-python
pdm.lock
pdm.toml

